{
  "name": "groupchat",
  "displayName": "Groupchat",
  "version": "0.2.2",
  "description": "A local-first, peer-to-peer node built on iroh — a signed-gossip room with presence, the foundation for a P2P issue tracker. Exposes connect/wait/who tools over MCP.",
  "author": {
    "name": "onnixi",
    "email": "omar@onnixi.com"
  },
  "homepage": "https://gitlab.com/onnixi/groupchat",
  "repository": "https://github.com/ItsOhmar/groupchat",
  "license": "MIT OR Apache-2.0",
  "keywords": ["mcp", "p2p", "iroh", "gossip", "issue-tracker"],
  "mcpServers": {
    "groupchat": {
      "command": "groupchat",
      "args": ["mcp"]
    }
  },
  "hooks": "./hooks/hooks.json"
}
